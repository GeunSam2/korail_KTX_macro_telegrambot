# Telegram Bot Configuration
BOTTOKEN=your_telegram_bot_token_here

# Korail Admin Credentials
USERID=your_korail_id_here
USERPW=your_korail_password_here

# User Access Control (comma-separated phone numbers)
# Leave empty to allow all users
ALLOW_LIST=010-1234-5678,010-9876-5432

# Redis Configuration (don't change these if using docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Optional: Redis password (uncomment if needed)
# REDIS_PASSWORD=your_redis_password

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=False

# Payment Timeout (minutes)
PAYMENT_TIMEOUT_MINUTES=10

# Logging
LOG_LEVEL=INFO
